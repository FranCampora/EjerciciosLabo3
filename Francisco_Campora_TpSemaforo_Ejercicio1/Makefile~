CC=gcc-4.1
FLAGS = -Wall -O3 -std=gnu89 -pedantic-errors -pthread
HEADERS = -I./
all: clean programa carga reservas

programa: main.c global.c clave.c reservas.c carga.c semaforo.c
	$(CC) -o programaExe main.c global.c clave.c ConsumidorConSemaforos.c Productor-ConSemaforos.c semaforo.c $(FLAGS) $(HEADERS)

carga: global.c clave.c semaforo.c carga.c
	$(CC) -o carga global.c clave.c semaforo.c carga.c funciones.c archivos.c $(FLAGS) $(HEADERS)

reservas: global.c clave.c semaforo.c reservas.c
	$(CC) -o reservas global.c clave.c semaforo.c reservas.c funciones.c archivos.c $(FLAGS) $(HEADERS)
clean:
	rm -rf *o programaExe carga reservas
