#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include "semaforo.h"
#include "unistd.h"
#include "archivos.h"
#include "funciones.h"
#include "def.h"


int main(int argc,char *argv[]){
	int numLote = 0;
	char nuevoNombre[LARGO];
	char numVuelo[LARGO];
	char destino[LARGO];
	char nomPasajero[LARGO];
	
	int id_semaforo;

	id_semaforo = creo_semaforo();

	
	while(1){
		if(abrirArchivo("lote.dat","r") == FALSE){
			printf("No se abre el LOTE\n");/*r es solo para lectura, si el file no existe falla*/

		}else{
			cerrarArchivo();
			espera_semaforo(id_semaforo);
			abrirArchivo("lote.dat","r");
			while(leerArchivo(numVuelo) == TRUE){
				leerArchivo(destino);
				leerArchivo(nomPasajero);
				printf("Vuelo: %s, desstino:%s, pasajero:%s\n",numVuelo,destino,nomPasajero);
			/*va leyendo en el file primero encontrando el num de vuelo, despues el destino y despues el nombre del pasajero*/
			}
			cerrarArchivo();

			sprintf(nuevoNombre,"lote.%03d.dat",numLote);/*armo el nuevo nombre del file. %03d le da 3 digitos antes*/
			rename("lote.dat",nuevoNombre);/*1er parametro el nombre del file, 2do el nuevo q le estoy dando*/
			numLote++;
			
		}
		levanta_semaforo(id_semaforo);	
		usleep(2000*1000);

	}
	return 0;
}
