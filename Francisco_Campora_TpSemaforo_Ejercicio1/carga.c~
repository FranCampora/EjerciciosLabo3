#include "archivos.h"

int main(int argc,char *argv[]){
	int numVuelo = 0;
	char destino[LARGO];
	char nomPasajero[LARGO];
	char linea[LARGO];

	int id_semaforo;

	id_semaforo = creo_semaforo();
	inicia_semaforo(id_semaforo, VERDE);
	/*la logica es: se ejecutan los 2 programas, primero incia en la carga */

	espera_semaforo(id_semaforo);

	if(abrirArchivo("lote.dat","a")== FALSE ){/*lo abre en modo append*/
		printf("No se puedo abrir el file lote.datn");
		levanta_semaforo(id_semaforo);/*se le saca el uso a la carga*/
		return 1;
	}

	numVuelo = cargarInt("Vuelo (0 para terminar): ");
	while(numVuelo != 0){
		cargarChar("Destino de vuelo: ", destino);
		cargarChar("NOmbre de pasajero: ", nomPasajero);
		memset(linea,0x00,sizeof(linea));
		sprintf(linea, "%d %s %s\n", numVuelo, destino, nomPasajero);
		if(escribirArchivo(linea) == FALSE){
			printf("No se pudo escribir el vuelo %d en el lote.dat",numVuelo);
			cerrarArchivo();
			
			levanta_semaforo(id_semaforo);/*se le saca el uso a la carga*/
			usleep(2000*1000);
			return 1;
		}


		numVuelo = cargarInt("Vuelo (0 para terminar): ");

		}
	cerrarArchivo();
	levanta_semaforo(id_semaforo);/*se le saca el uso a la carga*/
	usleep(2000*1000);
	return 0;
}
