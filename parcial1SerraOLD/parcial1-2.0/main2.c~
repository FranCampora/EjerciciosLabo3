#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <sys/ipc.h>
#include <sys/sem.h>
#include <time.h>
#include <unistd.h>

#include "define.h"
#include "global.h"
#include "semaforo.h"
#include "archivos.h"
#include "funciones.h"


int main(int argC, char *argv[])
{
	int nroCajero, id_semaforo, nroUsuario, opcion;
	int tipoDolar, dolarCantidad, pesosCantidad, precioCompra;

/*Verifico que se haya ingresado el numero de cajero*/
	if(argC != 2) {
		printf("\nIngresa como parametro el numero del cajero \n%s {numero}\n\n", argv[0]);
			exit(1);
	}

	nroCajero = atoi(argv[1]); /*Convierto el numero de cajero a int*/
	
/*Verifico que el numero de cajerjo sea correcto*/
	if(nroCajero < 1 || nroCajero > CAJEROS){
		printf("\nNumero de cajero incorrecto\nDebe ser 1 o 2\n\n");
		exit(1);
	}

	if(existe(ARCHIVO) == FALSE){
		printf("\nCajero inhabilitado\n");
		exit(1);
	}

	printf("\nCajero numero %d\n",nroCajero);
	

	id_semaforo = crearSemaforo(); 
/*Devuelve el id del semaforo inicializado por el banco. 
Por la flag IPC_CREAT del semget(), si no existe lo crea*/
	
	while(1){

/*Si espero el semaforo antes de pedir los ingresos y finalizo el programa, no se levanta el semaforo y el banco no lee el archivo.
Podría verificar el semaforo y levantarlo dentro de "ingresarUsuario()" ??*/

		esperarSemaforo(id_semaforo);

		nroUsuario = ingresarUsuario();
		
		opcion = menu();

		if(opcion == 1)
		{
			tipoDolar = ingresarTipoDolar();
			dolarCantidad = ingresarDolarCantidad();


			precioCompra = calcularPrecioCompra(&tipoDolar, &dolarCantidad);

			if(actualizarSaldoCompra(&nroUsuario,&precioCompra)){
				printf("\nEl usuario %d ha comprado U$S%d\n",nroUsuario,dolarCantidad);
			}
		}else if(opcion == 2){
			pesosCantidad = ingresarPesosCantidad();


		}
		


		levantarSemaforo(id_semaforo);
		usleep(200 * MS);
	}
	return 0;
}


