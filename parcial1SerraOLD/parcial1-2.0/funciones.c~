void cargarArchivoInicial()
{
	int i;	
	abrirArchivo(ARCHIVO, "w");
	for(i=0;i<USUARIOS_MAX;i++){
		fprintf(fp,"Usuario %d -- saldo $%d\n",i+1,SALDO_INICIAL);
	}
	cerrarArchivo();
	printf("\n%d usuarios creados con un saldo inicial de $%d\n",USUARIOS_MAX,SALDO_INICIAL);
}


int saldoUsuario(int *nroUsuario)
{
	Usuario usuarios[USUARIOS_MAX];
	int saldoActual = 0;
	int encontrado = FALSE;
	int i;
	
	/*Cargo el array local de usuarios con sus saldos*/
	abrirArchivo(ARCHIVO,"r");
	
	for(i=0;i<USUARIOS_MAX;i++){	
		fscanf(fp, "Usuario %d -- saldo $%d\n",&usuarios[i].numero, &usuarios[i].saldo);
		
		if(usuarios[i].numero == *nroUsuario){
			saldoActual = usuarios[i].saldo;
			encontrado = TRUE;
		}
	}
	cerrarArchivo();
	
	if(encontrado == FALSE){
		printf("No se encontró el usuario %d\n",*nroUsuario);
		return FALSE;
	}
	
	return saldoActual;
}


int calcularPrecioCompra(int *tipoDolar, int *cantidad)
{
	int pesos = 0;
	char nombre[CORTO];

	printf("\nCalculando el precio de la compra...\n");

	if(*tipoDolar == 1){
		pesos = *cantidad * MEP;
		strcpy(nombre,"MEP");
	}else if(*tipoDolar == 2){
		pesos = *cantidad * OFICIAL;
		strcpy(nombre,"Oficial");
	}else if(*tipoDolar == 3){
		pesos = *cantidad * BLUE;
		strcpy(nombre,"Blue");
	}
	printf("Precio en pesos por la compra de U$D%d a precio %s -- $%d\n\n", *cantidad,nombre,pesos);
	
	return pesos * (-1);

}

int calcularNuevoSaldo(int *saldoActual, int *pesos)
{
	int nuevoSaldo;

	nuevoSaldo = *saldoActual + (*pesos);

	if (nuevoSaldo < 0)
	{
		printf("El saldo es insuficiente para comprar esa cantidad de dolares\n");
		return FALSE;
	}

	return nuevoSaldo;
}

int actualizarSaldo(int *nroUsuario, int *nuevoSaldo)
{
	Usuario usuarios[USUARIOS_MAX];
	int encontrado = FALSE;
	int i,j;

/*Cargo el array local de usuarios con sus saldos*/
	abrirArchivo(ARCHIVO,"r");

	for(i=0;i<USUARIOS_MAX;i++){	
		fscanf(fp, "Usuario %d -- saldo $%d\n",&usuarios[i].numero, &usuarios[i].saldo);

		if(usuarios[i].numero == *nroUsuario){
			usuarios[i].saldo = *nuevoSaldo;
			encontrado = TRUE;
		}
	}
	cerrarArchivo();
	
	if(encontrado == FALSE){
		printf("No se encontró el usuario %d\n",*nroUsuario);
		return FALSE;
	}

/*Reescribo el archivo con los datos del array local actualizado*/
	abrirArchivo(ARCHIVO,"w");

	for(j=0;j<USUARIOS_MAX;j++){
		fprintf(fp, "Usuario %d -- saldo $%d\n",usuarios[j].numero, usuarios[j].saldo);
	}
	cerrarArchivo();

	return TRUE;
}



